# Application
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1
APP_URL=http://localhost:3000

# Database (for app)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/onefin_db?schema=public"

# Database (for docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-postgres-password
POSTGRES_DB=onefin_db

# JWT
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Default password for users (when not provided)
DEFAULT_USER_PASSWORD=1Fin@2024

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-secure-redis-password

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=your-secure-rabbitmq-password

# AWS S3
AWS_S3_BUCKET=onefin-files
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# Firebase
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
# Private key — choose ONE of the two below.
# Preferred (no newline/quoting headaches): base64 of the whole PEM.
#   Generate:  base64 -w0 service-account-private-key.pem
FIREBASE_PRIVATE_KEY_BASE64=
# Fallback: raw PEM with escaped newlines, wrapped in double quotes.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
